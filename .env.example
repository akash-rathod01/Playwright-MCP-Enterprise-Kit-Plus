# Environment Configuration
# Copy this file to .env and fill in your values

# ====================
# General Configuration
# ====================
BASE_URL=https://example.com
CI=false

# ====================
# Workday Configuration
# ====================
WORKDAY_URL=https://impl.workday.com/wday/authgwy/onetp4/login.htmld?redirect=n
WORKDAY_USERNAME=your-username-here
WORKDAY_PASSWORD=your-password-here
WORKDAY_PROXY_TARGET=Camille Sunga

# ====================
# GitHub Integration
# ====================
GH_TOKEN=your-github-token-here
GH_OWNER=your-org-or-username
GH_REPO=your-repo-name

# ====================
# Jira Integration
# ====================
JIRA_HOST=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=PROJ

# ====================
# Playwright Configuration
# ====================
# PLAYWRIGHT_SLOWMO=100
# PW_SLOWMO=100
