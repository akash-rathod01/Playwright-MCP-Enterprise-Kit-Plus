{
  "name": "playwright-mcp-enterprise-kit-plus",
  "version": "1.1.0",
  "license": "MIT",
  "author": "Akash Rathod",
  "type": "module",
  "description": "Enterprise Playwright + MCP starter with Allure reporting, GitHub/Jira issue integration, ZAP & Lighthouse CI, and repository templates.",
  "repository": {
    "type": "git",
    "url": "https://github.com/akash-rathod01/Playwright-MCP-Enterprise-Kit-Plus.git"
  },
  "bugs": {
    "url": "https://github.com/akash-rathod01/Playwright-MCP-Enterprise-Kit-Plus/issues"
  },
  "homepage": "https://github.com/akash-rathod01/Playwright-MCP-Enterprise-Kit-Plus#readme",
  "keywords": [
    "playwright",
    "testing",
    "e2e",
    "mcp",
    "model-context-protocol",
    "automation",
    "typescript",
    "allure",
    "test-framework",
    "enterprise",
    "accessibility",
    "security-testing",
    "ci-cd"
  ],
  "scripts": {
    "prepare": "playwright install --with-deps",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:report": "playwright show-report",
    "test:a11y": "playwright test src/tests/web/accessibility.spec.ts",
    "allure:generate": "allure generate ./allure-results --clean -o ./allure-report",
    "allure:open": "allure open ./allure-report",
    "zap:baseline": "node security/zap/scripts/runZapBaseline.js",
    "zap:full": "node security/zap/scripts/runZapFullScan.js",
    "lhci:autorun": "lhci autorun",
    "mcp:server": "tsx src/mcp/server.ts",
    "issues:github": "tsx integrations/github/reportFailuresToIssues.ts",
    "issues:jira": "tsx integrations/jira/reportFailuresToIssues.ts"
  },
  "dependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@modelcontextprotocol/sdk": "^1.22.0",
    "@octokit/rest": "^20.0.0",
    "jira-client": "^8.2.2",
    "zod": "^3.25.8"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.0",
    "@playwright/test": "^1.49.0",
    "@reportportal/agent-js-playwright": "^5.4.0",
    "@types/node": "^22.8.0",
    "allure-commandline": "^2.34.1",
    "allure-playwright": "^3.4.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "xml2js": "^0.6.2"
  }
}
